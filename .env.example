# Copy this file to .env — no edits needed if you ran init_db.sql as-is.
# The user/password below are created by init_db.sql.
DATABASE_URL=postgresql://quickverse_user:quickverse_pass@localhost:5432/quickverse

# Do not change this — it points to the live Quickverse API.
ADMIN_DECK_BASE_URL=http://prd.quickverse.in/quickVerse

# Optional — only needed for the Live Map page.
# Get a key from https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=
