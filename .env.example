# ─── Database ────────────────────────────────────────────────────────────────
# Matches the user/password created by database/setup.sql.
# No changes needed if you ran that script as-is.
DATABASE_URL=postgresql://quickverse_user:quickverse_pass@localhost:5432/quickverse

# ─── External Quickverse API ─────────────────────────────────────────────────
# Do not change — this is the live platform endpoint.
ADMIN_DECK_BASE_URL=http://prd.quickverse.in/quickVerse

# Shared platform credential used by the admin deck.
# Do not change — all instances of this app use the same key.
ADMIN_DECK_BASIC_AUTH=Basic cXZDYXN0bGVFbnRyeTpjYSR0bGVfUGVybWl0QDAx

# ─── Google Maps (optional) ──────────────────────────────────────────────────
# Required only for the Live Map page. Leave blank to disable the map.
# Get a key at: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=
